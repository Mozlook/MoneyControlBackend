# --- App ---
APP_ENV=dev
APP_PORT=8080
LOG_LEVEL=info
TZ=Europe/Warsaw

# Default home currency for reporting (multi-currency supported)
HOME_CURRENCY=PLN

# --- PostgreSQL ---
# Prefer a full DSN; the app should read DATABASE_URL first.
# Example (will change when docker-compose is added):
# DATABASE_URL=postgres://moneycontrol:moneycontrol@localhost:5432/moneycontrol?sslmode=disable
DATABASE_URL=

# If DATABASE_URL is empty, the app can build it from these:
DB_HOST=localhost          # in docker-compose it may be the service name, e.g. "postgres"
DB_PORT=5432
DB_USER=moneycontrol
DB_PASSWORD=moneycontrol
DB_NAME=moneycontrol

# --- Migrations ---
MIGRATIONS_DIR=./db/migrations

# --- OIDC (start with your own provider; add Google later) ---
OIDC_PROVIDER=custom
OIDC_ISSUER_URL=https://your-issuer.example.com/      # /.well-known/openid-configuration must exist
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URL=http://localhost:8080/auth/oidc/callback
OIDC_SCOPES=openid,profile,email
OIDC_JWKS_CACHE_TTL=300s

# --- App-issued tokens (if you mint your own JWTs) ---
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=168h
AUTH_JWT_SIGNING_KEY=change-me-strong-secret

# --- Import/Export ---
IMPORT_MAX_FILE_MB=25
EXPORT_MAX_ROWS=100000

